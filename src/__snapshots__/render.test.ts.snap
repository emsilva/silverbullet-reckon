// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`integration — evaluate(text) → renderSheet(result) > snapshots the full pipeline for a canonical mixed input 1`] = `
"<table class="reckon">
<tr class="comment"><td class="source" colspan="2">Project budget Q2</td></tr>
<tr class="blank"><td colspan="2"></td></tr>
<tr class="assignment"><td class="source"><span class="t-id">tax</span> <span class="t-op">=</span> <span class="t-num">20</span><span class="t-pct">%</span></td><td class="result" data-clipboard-value="0.2">20%</td></tr>
<tr class="assignment"><td class="source"><span class="t-id">salary</span> <span class="t-op">=</span> <span class="t-num">200000</span></td><td class="result" data-clipboard-value="200000">200,000</td></tr>
<tr class="value"><td class="source"><span class="t-num">100</span> <span class="t-op">+</span> <span class="t-num">20</span><span class="t-pct">%</span></td><td class="result" data-clipboard-value="120">120</td></tr>
<tr class="value"><td class="source"><span class="t-num">100</span> <span class="t-unit">km</span> <span class="t-kw">in</span> <span class="t-unit">miles</span></td><td class="result" data-clipboard-value="62.13711922373339">62.13711922373339 miles</td></tr>
