<tr class="value"><td class="source"><span class="t-num">5</span> # <span class="t-id">inline</span> <span class="t-id">comment</span></td><td class="result" data-clipboard-value="5">5</td></tr>
<tr class="total"><td class="label">Total</td><td class="result" data-clipboard-value="485">485</td></tr>
